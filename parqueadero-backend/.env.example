# Cambia estos valores antes de producción.
APP_TIMEZONE=America/Bogota
JWT_SECRET=generar_un_valor_largo_y_secreto
ADMIN_USERNAME=admin@empresa.com
ADMIN_PASSWORD=ColocaUnaClaveSeguraAqui
ACCESS_TOKEN_EXPIRE_MINUTES=720
PUBLIC_BASE_URL=http://127.0.0.1:8000

# LMS/MELI Okta SSO - requiere registrar esta app en Okta/MELI.
LMS_AUTH_URL=https://auth-meli.adminml.com
OIDC_ISSUER=https://auth-meli.adminml.com
OIDC_CLIENT_ID=client_id_entregado_por_okta
# Solo si la app Okta fue creada como confidential/web app:
# OIDC_CLIENT_SECRET=client_secret_entregado_por_okta
OIDC_SCOPES=openid profile email groups
LOCAL_LOGIN_ENABLED=true
# Usuarios/grupos que serán admin al entrar con MELI/Okta, separados por coma.
OIDC_ADMIN_USERS=
OIDC_ADMIN_GROUPS=

# Usuarios por rol estilo AppSheet. Las claves se inyectan por entorno, no se commitean.
# Si APP_ROLE_DEFAULT_PASSWORD existe, crea los 6 usuarios de rol con esa misma clave.
# APP_ROLE_DEFAULT_PASSWORD=
# Alternativa por rol:
# APP_ROLE_PASSWORDS_JSON={"Conductor":"clave","Coordinador MLP":"clave","Operación MELI":"clave"}
# Opcional: sobrescribir usernames por rol.
# APP_ROLE_USERNAMES_JSON={"Conductor":"conductor@empresa.com","Operación MELI":"operacion@empresa.com"}

# Google Sheets / CONTROL ARRIBOS
GOOGLE_SHEET_ID=1UM29RveA97jOkbKFifBNDhRsD4GTlltD2DHyF1xwMLA
GOOGLE_SHEET_NAME=CONTROL ARRIBOS
GOOGLE_ROLES_SHEET_NAME=Lista_Roles
GOOGLE_FLASH_SHEET_NAME=Flash_Parking
# Si es true, un error escribiendo Flash_Parking bloquea el ingreso/salida.
GOOGLE_FLASH_LOG_REQUIRED=false
# Recomendado: pega el JSON de una Google Service Account en base64 y comparte el Sheet
# con el email client_email de esa service account. Para Flash_Parking debe tener permiso Editor.
# GOOGLE_SERVICE_ACCOUNT_JSON_B64=
# Alternativa menos segura: publicar la hoja como CSV y poner la URL aquí.
# GOOGLE_PUBLIC_CSV_URL=

# Redirect URI que debe estar permitido en Okta para desarrollo local:
# http://127.0.0.1:8000/api/auth/oidc/callback

# Local usa SQLite automáticamente.
# En Railway/PostgreSQL se inyecta DATABASE_URL desde el servicio de base de datos.
# DATABASE_URL=postgresql://usuario:password@host:puerto/db
